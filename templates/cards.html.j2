<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<style>
  @font-face {
    font-family: "KanjiFont";
    src: url("{{ kanji_font_url }}") format("truetype");
    font-weight: 600;
  }
  @font-face {
    font-family: "SansJP";
    src: url("{{ sans_font_url }}") format("truetype");
    font-weight: 400;
  }
  @font-face {
    font-family: "SansJP";
    src: url("{{ sans_bold_font_url }}") format("truetype");
    font-weight: 700;
  }

  @page {
    size: {{ paper }};
    margin: 10mm;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    font-family: "SansJP", sans-serif;
    color: #1a1a1a;
  }

  /* Eine Seite = ein Raster aus cols x rows Karten. */
  .sheet {
    display: grid;
    grid-template-columns: repeat({{ cols }}, 1fr);
    grid-template-rows: repeat({{ rows }}, 1fr);
    width: 100%;
    height: 100%;
    gap: 0;
    page-break-after: always;
  }
  .sheet:last-child { page-break-after: auto; }

  .card {
    position: relative;
    padding: 6mm;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    {% if cut_marks %}
    outline: 0.2mm dashed #c9c9c9;
    outline-offset: -0.1mm;
    {% endif %}
  }
  .card.empty { outline: none; }

  /* ---------- Vorderseite: nur das Kanji, riesig & zentriert ---------- */
  .card.front {
    align-items: center;
    justify-content: center;
  }
  .front .kanji {
    font-family: "KanjiFont", serif;
    font-size: 150pt;
    line-height: 1;
    font-weight: 600;
  }

  /* ---------- Rückseite ---------- */
  .card.back {
    justify-content: flex-start;
    gap: 2.4mm;
  }
  .back .meanings {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 15pt;
    line-height: 1.15;
    color: #111;
  }
  .back .meanings .secondary {
    font-weight: 400;
    font-size: 10.5pt;
    color: #666;
  }

  .readings {
    display: flex;
    flex-direction: column;
    gap: 1.2mm;
  }
  .reading-row {
    display: flex;
    align-items: baseline;
    gap: 2.5mm;
  }
  .reading-row .label {
    flex: 0 0 15mm;
    font-size: 8pt;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #a23b2e;   /* dezentes WaniKani-Rot für On */
    font-weight: 700;
    padding-top: 1pt;
  }
  .reading-row.kun .label { color: #2e5aa2; }  /* Blau für Kun */
  .reading-row .value {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 13pt;
    line-height: 1.3;
    color: #1a1a1a;
  }

  hr.divider {
    border: none;
    border-top: 0.3mm solid #e6e6e6;
    margin: 0.6mm 0;
    width: 100%;
  }

  .vocab {
    display: flex;
    flex-direction: column;
    gap: 0.8mm;
  }
  .vocab .head {
    display: flex;
    align-items: baseline;
    gap: 2.5mm;
  }
  .vocab .word {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 15pt;
    font-weight: 600;
  }
  .vocab .gloss {
    font-size: 10pt;
    color: #555;
  }

  .sentence {
    margin-top: auto;   /* Beispielsatz nach unten schieben */
  }
  .sentence .ja {
    font-family: "SansJP", sans-serif;
    font-size: 10.5pt;
    line-height: 1.4;
    color: #1a1a1a;
    word-break: break-all;   /* sauberer CJK-Umbruch */
    line-break: strict;
  }
  .sentence .en {
    font-size: 8.5pt;
    line-height: 1.35;
    color: #777;
    font-style: italic;
    margin-top: 0.6mm;
  }

  .kanji-mini {
    position: absolute;
    top: 4mm;
    right: 5mm;
    font-family: "KanjiFont", serif;
    font-size: 20pt;
    color: #dcdcdc;
    font-weight: 600;
  }
</style>
</head>
<body>
{% for sheet in sheets %}
  <div class="sheet">
    {% for cell in sheet.cells %}
      {% if cell is none %}
        <div class="card empty"></div>
      {% elif sheet.side == "front" %}
        <div class="card front">
          <div class="kanji">{{ cell.kanji }}</div>
        </div>
      {% else %}
        <div class="card back">
          <div class="kanji-mini">{{ cell.kanji }}</div>

          {% if cell.meanings %}
          <div class="meanings">
            {{ cell.meanings[0] }}{% if cell.meanings[1:] %}<span class="secondary">&nbsp;· {{ cell.meanings[1:] | join(", ") }}</span>{% endif %}
          </div>
          {% endif %}

          <div class="readings">
            {% if cell.onyomi %}
            <div class="reading-row on">
              <div class="label">On</div>
              <div class="value">{{ cell.onyomi | join("、") }}</div>
            </div>
            {% endif %}
            {% if cell.kunyomi %}
            <div class="reading-row kun">
              <div class="label">Kun</div>
              <div class="value">{{ cell.kunyomi | join("、") }}</div>
            </div>
            {% endif %}
          </div>

          {% if cell.vocab %}
          <hr class="divider">
          <div class="vocab">
            <div class="head">
              <span class="word">{{ cell.vocab }}</span>
              {% if cell.vocab_meaning %}<span class="gloss">{{ cell.vocab_meaning }}</span>{% endif %}
            </div>
          </div>
          {% endif %}

          {% if cell.sentence_ja %}
          <div class="sentence">
            <div class="ja">{{ cell.sentence_ja }}</div>
            {% if cell.sentence_en %}<div class="en">{{ cell.sentence_en }}</div>{% endif %}
          </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
{% endfor %}
</body>
</html>
