<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<style>
  @font-face {
    font-family: "KanjiFont";
    src: url("{{ kanji_font_url }}") format("truetype");
    font-weight: 600;
  }
  @font-face {
    font-family: "SansJP";
    src: url("{{ sans_font_url }}") format("truetype");
    font-weight: 400;
  }
  @font-face {
    font-family: "SansJP";
    src: url("{{ sans_bold_font_url }}") format("truetype");
    font-weight: 700;
  }

  @page {
    size: {{ page_w }}mm {{ page_h }}mm;
    margin: {{ margin }}mm;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    font-family: "SansJP", sans-serif;
    color: #1a1a1a;
    /* Whitespace zwischen den Seiten-Divs darf keine Zeilenhöhe erzeugen,
       sonst überläuft das randlose Raster um Sub-mm → Leerseiten. */
    line-height: 0;
  }

  /* Eine Seite = ein Raster aus cols x rows Karten mit FESTER Geometrie.
     Feste mm-Maße (statt height:100%) sind entscheidend, damit Vorder- und
     Rückseite exakt deckungsgleich sind und die Schnittkanten passen. */
  .sheet {
    position: relative;
    width: {{ content_w }}mm;
    height: {{ content_h }}mm;
    page-break-after: always;
  }
  .sheet:last-child { page-break-after: auto; }

  {% if show_cross %}
  /* Nur ZWEI Schnittkanten: mittiges Kreuz (senkrecht + waagerecht).
     Als Overlay gezeichnet, damit die Zellengröße exakt gleich bleibt. */
  .sheet::before,
  .sheet::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }
  .sheet::before {   /* senkrechte Mittellinie */
    top: 0; bottom: 0; left: 50%;
    border-left: 0.25mm dashed #b4b4b4;
  }
  .sheet::after {    /* waagerechte Mittellinie */
    left: 0; right: 0; top: 50%;
    border-top: 0.25mm dashed #b4b4b4;
  }
  {% endif %}

  /* Karten absolut positioniert (per Inline-Style je Zelle): so sind sie aus
     dem Fluss genommen und eine Seite kann niemals überlaufen/fragmentieren. */
  .card {
    position: absolute;
    width: {{ cell_w }}mm;
    height: {{ cell_h }}mm;
    padding: 7mm;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    line-height: 1.3;
  }

  /* ---------- Lochbereich (optional) ----------
     Das Loch wird durch die fertige Karte gestanzt und muss auf beiden Seiten
     frei bleiben. Vorne oben LINKS; hinten je nach Wende-Kante gespiegelt
     (long-edge → oben rechts, short-edge → unten links). */
  {% if show_hole %}
  .hole {
    position: absolute;
    width: 6mm;
    height: 6mm;
    border: 0.3mm dashed #9a9a9a;
    border-radius: 50%;
  }
  .card.front .hole { top: 6mm; left: 6mm; }
  {% if duplex == "short-edge" %}
  .card.back .hole { bottom: 6mm; left: 6mm; }
  {% else %}
  .card.back .hole { top: 6mm; right: 6mm; }
  {% endif %}
  .card.empty .hole { display: none; }
  {% endif %}

  /* Rückseite: oben ein Band für die Tags; bei aktivem Loch (long-edge) mehr
     Platz, da das Loch dann oben rechts sitzt. */
  .card.back {
    padding-top: {{ 15 if (show_hole and duplex != "short-edge") else 7 }}mm;
    {% if show_hole and duplex == "short-edge" %}padding-bottom: 15mm;{% endif %}
  }

  /* ---------- Tags (oben rechts auf der VORDERSEITE) ----------
     Das Loch sitzt vorne oben links → Tags oben rechts kollidieren nie damit.
     Kein Flexbox: absolut positionierte Flex-Container zeichnen in WeasyPrint
     die Ränder doppelt; inline-block + margin vermeidet das. */
  .tags {
    position: absolute;
    top: 5mm;
    right: 6mm;
    text-align: right;
    white-space: nowrap;
    z-index: 2;
  }
  .tag {
    display: inline-block;
    font-family: "SansJP", sans-serif;
    font-size: 6.6pt;
    font-weight: 700;
    letter-spacing: .4px;
    text-transform: uppercase;
    color: #111;
    border: 0.3mm solid #111;
    border-radius: 1mm;          /* Rechteck mit leicht abgerundeten Ecken */
    padding: 0.5mm 2.2mm;
    background: #fff;
    white-space: nowrap;
  }
  .tag + .tag { margin-left: 1.4mm; }

  /* Dezenter Benutzername unten rechts auf der Rückseite. */
  .username {
    position: absolute;
    bottom: {{ 15 if (show_hole and duplex == "short-edge") else 3.5 }}mm;
    right: 6mm;
    font-family: "SansJP", sans-serif;
    font-size: 6.2pt;
    letter-spacing: .3px;
    color: #b6b6b6;
  }

  /* ---------- Vorderseite: nur das Kanji, riesig & zentriert ---------- */
  .card.front {
    align-items: center;
    justify-content: center;
  }
  .front .kanji {
    font-family: "KanjiFont", serif;
    font-size: 150pt;
    line-height: 1;
    font-weight: 600;
  }

  /* ---------- Deckkarte: Vorderseite (schwarz auf weiß, tintensparend) ---------- */
  .cover-front {
    align-items: center;
    justify-content: center;
    background: #fff;
    color: #111;
    text-align: center;
    border: 0.6mm solid #111;   /* dezenter Rahmen als Struktur (wenig Tinte) */
  }
  .cover-brand {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 26pt;
    letter-spacing: 0.5px;
    line-height: 1.05;
  }
  .cover-level {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 42pt;
    line-height: 1.1;
    margin-top: 2.5mm;
  }
  .cover-kind {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 15pt;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-top: 3.5mm;
    padding: 1.2mm 3.5mm;
    border: 0.4mm solid #111;
    border-radius: 1mm;
  }
  .cover-count {
    font-size: 11pt;
    color: #666;
    margin-top: 3mm;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ---------- Deckkarte: Rückseite (Kanji-Übersicht) ---------- */
  .cover-back { display: block; }
  .cover-back-title {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 12pt;
    color: #111;
    margin-bottom: 2.5mm;
  }
  /* Spaltenzahl + Basis-Schriftgröße werden je nach Kanji-Anzahl per
     Inline-Style gesetzt (siehe unten); .cl-* skalieren relativ dazu (em),
     damit auch volle Level (~35+ Kanji) sauber auf die Karte passen. */
  ul.cover-list {
    list-style: none;
    margin: 0;
    padding: 0;
    column-gap: 5mm;
    font-size: 10pt;   /* Default; per Inline-Style überschrieben */
  }
  ul.cover-list li {
    display: flex;
    align-items: baseline;
    gap: 1.6mm;
    break-inside: avoid;
    margin-bottom: 0.55em;
  }
  ul.cover-list .cl-k {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 1.35em;
    font-weight: 600;
    flex: 0 0 auto;
  }
  ul.cover-list .cl-m {
    font-size: 0.92em;
    color: #555;
    line-height: 1.12;
  }

  /* ---------- Radical: Vorderseite ---------- */
  .radical-front .radical-img {
    height: 42mm;      /* feste Höhe: SVGs ohne intrinsische Größe skalieren sonst nicht */
    width: auto;
    max-width: 80%;
    object-fit: contain;
  }
  .radical-front .radical-fallback {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 30pt;
    text-align: center;
    line-height: 1.1;
  }

  /* ---------- Radical: Rückseite ---------- */
  .rk-title {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 9pt;
    color: #111;
    margin-bottom: 1mm;
  }
  ul.rk-list {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 2;
    column-gap: 5mm;
    font-size: 8.5pt;
  }
  ul.rk-list li {
    display: flex;
    align-items: baseline;
    gap: 1.4mm;
    break-inside: avoid;
    margin-bottom: 0.5em;
  }
  ul.rk-list .rk-k {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 1.3em;
    font-weight: 600;
    flex: 0 0 auto;
  }
  ul.rk-list .rk-r {
    color: #a23b2e;
    font-size: 0.92em;
    flex: 0 0 auto;
  }
  ul.rk-list .rk-m {
    color: #555;
    font-size: 0.92em;
    line-height: 1.12;
  }

  /* ---------- Vokabel: Vorderseite ---------- */
  .vocab-front { align-items: center; justify-content: center; }
  .vocab-front .vword {
    font-family: "KanjiFont", "SansJP", serif;
    font-weight: 600;
    line-height: 1.05;
    text-align: center;
  }
  /* ---------- Vokabel: Rückseite ---------- */
  .back .pos {
    font-size: 8.5pt;
    color: #8a8f98;
    font-style: italic;
    margin: -0.5mm 0 2mm;
  }

  /* ---------- Freie Karte (Rich-Text) ---------- */
  .free-front {
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .free-front .free-html { width: 100%; }
  /* Standard-Optik Vorderseite: groß & zentriert (im Editor gleiche Klasse). */
  .free-front .free-big, .free-html .free-big {
    font-family: "KanjiFont", "SansJP", serif;
    font-weight: 600;
    font-size: 60pt;
    line-height: 1.08;
  }
  .free-back { display: block; }
  .free-html { font-family: "SansJP", sans-serif; font-size: 10.5pt; line-height: 1.4; color: #1a1a1a; }
  .free-html p { margin: 0 0 1.6mm; }
  .free-html img { max-width: 100%; max-height: 45mm; object-fit: contain; }
  .free-html ul, .free-html ol { margin: 1mm 0 1.6mm; padding-left: 5mm; }
  /* Titel (wie Kanji-Karte: fett & etwas größer) */
  .free-html .c-title {
    display: block;
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 15pt;
    line-height: 1.15;
    color: #111;
    margin-bottom: 2mm;
  }
  /* Textbox wie MNEMONIC */
  .free-html .c-box {
    background: #faf7f1;
    border-left: 0.7mm solid #e2d6c2;
    border-radius: 0.6mm;
    padding: 1.8mm 2.4mm;
    margin: 2mm 0;
    font-size: 9pt;
    line-height: 1.3;
    color: #5a544c;
  }

  /* ---------- Rückseite ----------
     Normaler Blockfluss (kein Flex): so kann kein Abschnitt flex-geschrumpft
     werden und Texte überlappen nie; zu viel Inhalt wird am Kartenrand
     sauber abgeschnitten (overflow:hidden). */
  .card.back {
    display: block;
  }
  .back .meanings {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 14pt;
    line-height: 1.12;
    color: #111;
    margin-bottom: 2mm;
  }
  .back .meanings .secondary {
    font-weight: 400;
    font-size: 10pt;
    color: #666;
  }

  /* ---------- Referenz-Zeichen auf der Rückseite ----------
     Damit man nicht umdrehen muss: das Zeichen der Vorderseite (Kanji/Radical/
     Vokabel) steht auch hinten oben, deutlich kleiner als vorne, aber etwas
     größer als der übrige Text. Kopfzeile: Zeichen links, Bedeutung daneben. */
  .back-head {
    display: flex;
    align-items: baseline;
    gap: 3mm;
    margin-bottom: 2mm;
  }
  .back-head.has-img { align-items: center; }
  .back-head .meanings { margin-bottom: 0; }
  .back-char {
    flex: 0 0 auto;
    font-family: "KanjiFont", "SansJP", serif;
    font-weight: 600;
    font-size: 30pt;
    line-height: 1;
    color: #111;
  }
  .back-char.vocab-char { font-size: 24pt; }
  .back-char-img {
    flex: 0 0 auto;
    height: 13mm;
    width: auto;
    max-width: 32mm;
    object-fit: contain;
  }

  .readings {
    margin-bottom: 2mm;
  }
  .readings .reading-row + .reading-row { margin-top: 1mm; }
  .reading-row {
    display: flex;
    align-items: baseline;
    gap: 2.5mm;
  }
  .reading-row .label {
    flex: 0 0 15mm;
    font-size: 8pt;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #a23b2e;   /* dezentes WaniKani-Rot für On */
    font-weight: 700;
    padding-top: 1pt;
  }
  .reading-row.kun .label { color: #2e5aa2; }  /* Blau für Kun */
  .reading-row.gen .label { color: #444; }     /* neutral (freie Karten) */
  .reading-row .value {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 13pt;
    line-height: 1.3;
    color: #1a1a1a;
  }

  /* ---------- Composition (Radicals, aus denen das Kanji besteht) ----------
     Nutzt die volle Kartenbreite: die Bausteine fließen nebeneinander und
     brechen erst um, wenn die Zeile voll ist (spart vertikalen Platz). */
  .composition {
    margin-bottom: 2mm;
    line-height: 1.55;   /* Luft zwischen umbrochenen Zeilen */
  }
  .comp-label {
    font-size: 8pt;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #4a7a3a;      /* Grün, hebt sich von On (rot) / Kun (blau) ab */
    font-weight: 700;
    margin-right: 2.5mm;
  }
  .comp-item {
    display: inline-block;   /* fließt in der Zeile, umbricht als Ganzes */
    white-space: nowrap;     /* Zeichen + Bedeutung bleiben zusammen */
    margin-right: 3.5mm;     /* Abstand zwischen den Bausteinen */
    vertical-align: middle;
  }
  .comp-item .comp-k {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 12pt;
    font-weight: 600;
    color: #1a1a1a;
  }
  .comp-item .comp-img {
    height: 4.5mm;
    width: auto;
    max-width: 9mm;
    object-fit: contain;
    vertical-align: middle;
  }
  .comp-item .comp-m {
    font-family: "SansJP", sans-serif;
    font-size: 8.5pt;
    color: #555;
    margin-left: 1mm;
  }

  /* ---------- Eselsbrücken (Mnemonics) ---------- */
  .mnemonics {
    background: #faf7f1;
    border-left: 0.7mm solid #e2d6c2;
    border-radius: 0.6mm;
    padding: 1.6mm 2.2mm;
    margin-bottom: 2mm;
  }
  .mnemonic {
    font-size: 7.4pt;
    line-height: 1.28;
    color: #5a544c;
    text-align: justify;
  }
  .mnemonic + .mnemonic { margin-top: 1mm; }
  .mnemonic .mlabel {
    display: inline-block;
    font-size: 6.3pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin-right: 1.4mm;
    vertical-align: 1.5%;
  }
  .mnemonic .mlabel.meaning { color: #a2792e; }
  .mnemonic .mlabel.reading { color: #7a5a9e; }

  hr.divider {
    border: none;
    border-top: 0.3mm solid #e6e6e6;
    margin: 0.6mm 0;
    width: 100%;
  }

  .vocab {
    display: flex;
    flex-direction: column;
    gap: 0.8mm;
  }
  .vocab .head {
    display: flex;
    align-items: baseline;
    gap: 2.5mm;
  }
  .vocab .word {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 15pt;
    font-weight: 600;
  }
  .vocab .vreading {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 11pt;
    color: #444;
  }
  .vocab .gloss {
    font-size: 10pt;
    color: #555;
  }

  .sentence {
    margin-top: 1.6mm;
  }
  /* Zweiter Beispielsatz: dezent abgesetzt und etwas kompakter, damit die
     feste Kartenhöhe seltener knapp wird. */
  .sentence + .sentence {
    margin-top: 1.5mm;
    padding-top: 1.2mm;
    border-top: 0.25mm dotted #e2e2e2;
  }
  .sentence .ja {
    font-family: "SansJP", sans-serif;
    font-size: 10pt;
    line-height: 1.3;
    color: #1a1a1a;
    word-break: break-all;   /* sauberer CJK-Umbruch */
    line-break: strict;
  }
  .sentence .en {
    font-size: 8.5pt;
    line-height: 1.3;
    color: #777;
    font-style: italic;
    margin-top: 0.5mm;
  }
  .sentence + .sentence .ja { font-size: 8.5pt; }
  .sentence + .sentence .en { font-size: 7.5pt; }

  /* Kleines Referenz-Kanji im reservierten Loch-Band (Gegenseite zum Loch). */
  .kanji-mini {
    position: absolute;
    top: 4.5mm;
    font-family: "KanjiFont", serif;
    font-size: 19pt;
    line-height: 1;
    color: #cfcfcf;
    font-weight: 600;
  }
  {% if duplex == "short-edge" %}
  .kanji-mini { top: auto; bottom: 4.5mm; right: 6mm; }
  {% else %}
  .kanji-mini { left: 6mm; }
  {% endif %}
</style>
</head>
{% macro tags(cell) %}
  {% if cell.tags %}
  <div class="tags">
    {% for t in cell.tags %}<span class="tag {% if loop.first %}type{% endif %}">{{ t }}</span>{% endfor %}
  </div>
  {% endif %}
{% endmacro %}
<body>
{% for sheet in sheets %}
  <div class="sheet">
    {% for cell in sheet.cells %}
      {% set col = loop.index0 % cols %}
      {% set row = loop.index0 // cols %}
      {% set pos = "left:" ~ (col * cell_w) ~ "mm; top:" ~ (row * cell_h) ~ "mm;" %}
      {% if cell is none %}
        <div class="card empty" style="{{ pos }}"></div>

      {% elif sheet.side == "front" %}
        {% if cell.type == "cover" %}
        <div class="card front cover-front" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          <div class="cover-brand">{{ cell.title }}</div>
          <div class="cover-level">{{ cell.subtitle }}</div>
          <div class="cover-kind">{{ cell.kind }}</div>
          <div class="cover-count">{{ cell.count }} {{ cell.kind }}</div>
        </div>
        {% elif cell.type == "radical" %}
        <div class="card front radical-front" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          {{ tags(cell) }}
          {% if cell.radical %}
          <div class="kanji">{{ cell.radical }}</div>
          {% elif cell.image_uri %}
          <img class="radical-img" src="{{ cell.image_uri }}" alt="{{ cell.meaning }}">
          {% else %}
          <div class="radical-fallback">{{ cell.meaning }}</div>
          {% endif %}
        </div>
        {% elif cell.type == "vocab" %}
        {% set vl = cell.vocab | length %}
        {% if vl <= 1 %}{% set vfs = 128 %}{% elif vl == 2 %}{% set vfs = 108 %}
        {% elif vl == 3 %}{% set vfs = 86 %}{% elif vl == 4 %}{% set vfs = 70 %}
        {% else %}{% set vfs = 54 %}{% endif %}
        <div class="card front vocab-front" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          {{ tags(cell) }}
          <div class="vword" style="font-size: {{ vfs }}pt;">{{ cell.vocab }}</div>
        </div>
        {% elif cell.type == "custom" %}
        <div class="card front free-front" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          {{ tags(cell) }}
          <div class="free-html">{{ cell.front_html | safe }}</div>
        </div>
        {% else %}
        <div class="card front" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          {{ tags(cell) }}
          <div class="kanji">{{ cell.kanji }}</div>
        </div>
        {% endif %}

      {% elif cell.type == "cover" %}
        {% set n = cell.count %}
        {% if n <= 10 %}{% set lcols, lfs = 2, 11 %}
        {% elif n <= 21 %}{% set lcols, lfs = 3, 9.5 %}
        {% elif n <= 32 %}{% set lcols, lfs = 3, 8 %}
        {% elif n <= 44 %}{% set lcols, lfs = 4, 7.5 %}
        {% else %}{% set lcols, lfs = 4, 6.5 %}{% endif %}
        <div class="card back cover-back" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          <div class="cover-back-title">{{ cell.subtitle }} · Übersicht</div>
          <ul class="cover-list" style="columns: {{ lcols }}; font-size: {{ lfs }}pt;">
            {% for e in cell.entries %}
            <li><span class="cl-k">{{ e.kanji }}</span><span class="cl-m">{{ e.meaning }}</span></li>
            {% endfor %}
          </ul>
        </div>

      {% elif cell.type == "radical" %}
        <div class="card back radical-back" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          {% if username %}<div class="username">{{ username }}</div>{% endif %}
          <div class="back-head{% if not cell.radical and cell.image_uri %} has-img{% endif %}">
            {% if cell.radical %}<div class="back-char">{{ cell.radical }}</div>
            {% elif cell.image_uri %}<img class="back-char-img" src="{{ cell.image_uri }}" alt="{{ cell.meaning }}">{% endif %}
            {% if cell.meaning %}<div class="meanings">{{ cell.meaning }}</div>{% endif %}
          </div>

          {% if cell.mnemonic %}
          <div class="mnemonics">
            <div class="mnemonic"><span class="mlabel meaning">Mnemonic</span>{{ cell.mnemonic }}</div>
          </div>
          {% endif %}

          {% if cell.kanji_examples %}
          <hr class="divider">
          <div class="rk-title">Kanji</div>
          <ul class="rk-list">
            {% for e in cell.kanji_examples %}
            <li><span class="rk-k">{{ e.kanji }}</span>{% if e.reading %}<span class="rk-r">{{ e.reading }}</span>{% endif %}<span class="rk-m">{{ e.meaning }}</span></li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>

      {% elif cell.type == "vocab" %}
        <div class="card back" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          {% if username %}<div class="username">{{ username }}</div>{% endif %}
          <div class="back-head">
            {% if cell.vocab %}<div class="back-char vocab-char">{{ cell.vocab }}</div>{% endif %}
            {% if cell.meanings %}
            <div class="meanings">
              {{ cell.meanings[0] }}{% if cell.meanings[1:] %}<span class="secondary">&nbsp;· {{ cell.meanings[1:] | join(", ") }}</span>{% endif %}
            </div>
            {% endif %}
          </div>
          {% if cell.parts_of_speech %}<div class="pos">{{ cell.parts_of_speech | join(", ") }}</div>{% endif %}

          {% if cell.readings %}
          <div class="readings">
            <div class="reading-row on">
              <div class="label">Reading</div>
              <div class="value">{{ cell.readings | join("、") }}</div>
            </div>
          </div>
          {% endif %}

          {% if cell.meaning_mnemonic or cell.reading_mnemonic %}
          <div class="mnemonics">
            {% if cell.meaning_mnemonic %}
            <div class="mnemonic"><span class="mlabel meaning">Mnemonic</span>{{ cell.meaning_mnemonic }}</div>
            {% endif %}
            {% if cell.reading_mnemonic %}
            <div class="mnemonic"><span class="mlabel reading">Reading</span>{{ cell.reading_mnemonic }}</div>
            {% endif %}
          </div>
          {% endif %}

          {% for s in cell.sentences[:2] %}
          <div class="sentence">
            <div class="ja">{{ s.ja }}</div>
            {% if s.en %}<div class="en">{{ s.en }}</div>{% endif %}
          </div>
          {% endfor %}
        </div>

      {% elif cell.type == "custom" %}
        <div class="card back free-back" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          {% if username %}<div class="username">{{ username }}</div>{% endif %}
          <div class="free-html">{{ cell.back_html | safe }}</div>
        </div>

      {% else %}
        <div class="card back" style="{{ pos }}">
          {% if show_hole %}<div class="hole"></div>{% endif %}
          {% if username %}<div class="username">{{ username }}</div>{% endif %}
          <div class="back-head">
            {% if cell.kanji %}<div class="back-char">{{ cell.kanji }}</div>{% endif %}
            {% if cell.meanings %}
            <div class="meanings">
              {{ cell.meanings[0] }}{% if cell.meanings[1:] %}<span class="secondary">&nbsp;· {{ cell.meanings[1:] | join(", ") }}</span>{% endif %}
            </div>
            {% endif %}
          </div>

          <div class="readings">
            {% if cell.onyomi %}
            <div class="reading-row on">
              <div class="label">On</div>
              <div class="value">{{ cell.onyomi | join("、") }}</div>
            </div>
            {% endif %}
            {% if cell.kunyomi %}
            <div class="reading-row kun">
              <div class="label">Kun</div>
              <div class="value">{{ cell.kunyomi | join("、") }}</div>
            </div>
            {% endif %}
          </div>

          {% if cell.components %}
          <div class="composition">
            <span class="comp-label">Composition</span>
            {% for c in cell.components %}<span class="comp-item">{% if c.radical %}<span class="comp-k">{{ c.radical }}</span>{% elif c.image_uri %}<img class="comp-img" src="{{ c.image_uri }}" alt="{{ c.meaning }}">{% endif %}<span class="comp-m">{{ c.meaning }}</span></span>{% endfor %}
          </div>
          {% endif %}

          {% if cell.meaning_mnemonic or cell.reading_mnemonic %}
          <div class="mnemonics">
            {% if cell.meaning_mnemonic %}
            <div class="mnemonic"><span class="mlabel meaning">Mnemonic</span>{{ cell.meaning_mnemonic }}</div>
            {% endif %}
            {% if cell.reading_mnemonic %}
            <div class="mnemonic"><span class="mlabel reading">Reading</span>{{ cell.reading_mnemonic }}</div>
            {% endif %}
          </div>
          {% endif %}

          {% if cell.vocab %}
          <hr class="divider">
          <div class="vocab">
            <div class="head">
              <span class="word">{{ cell.vocab }}</span>
              {% if cell.vocab_reading %}<span class="vreading">{{ cell.vocab_reading }}</span>{% endif %}
              {% if cell.vocab_meaning %}<span class="gloss">{{ cell.vocab_meaning }}</span>{% endif %}
            </div>
          </div>
          {% endif %}

          {% for s in cell.sentences[:2] %}
          <div class="sentence">
            <div class="ja">{{ s.ja }}</div>
            {% if s.en %}<div class="en">{{ s.en }}</div>{% endif %}
          </div>
          {% endfor %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
{% endfor %}
</body>
</html>
