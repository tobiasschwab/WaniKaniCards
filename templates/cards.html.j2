<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<style>
  @font-face {
    font-family: "KanjiFont";
    src: url("{{ kanji_font_url }}") format("truetype");
    font-weight: 600;
  }
  @font-face {
    font-family: "SansJP";
    src: url("{{ sans_font_url }}") format("truetype");
    font-weight: 400;
  }
  @font-face {
    font-family: "SansJP";
    src: url("{{ sans_bold_font_url }}") format("truetype");
    font-weight: 700;
  }

  @page {
    size: {{ page_w }}mm {{ page_h }}mm;
    margin: {{ margin }}mm;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    font-family: "SansJP", sans-serif;
    color: #1a1a1a;
    /* Whitespace zwischen den Seiten-Divs darf keine Zeilenhöhe erzeugen,
       sonst überläuft das randlose Raster um Sub-mm → Leerseiten. */
    line-height: 0;
  }

  /* Eine Seite = ein Raster aus cols x rows Karten mit FESTER Geometrie.
     Feste mm-Maße (statt height:100%) sind entscheidend, damit Vorder- und
     Rückseite exakt deckungsgleich sind und die Schnittkanten passen. */
  .sheet {
    position: relative;
    width: {{ content_w }}mm;
    height: {{ content_h }}mm;
    page-break-after: always;
  }
  .sheet:last-child { page-break-after: auto; }

  {% if cut_marks %}
  /* Nur ZWEI Schnittkanten: mittiges Kreuz (senkrecht + waagerecht).
     Als Overlay gezeichnet, damit die Zellengröße exakt gleich bleibt. */
  .sheet::before,
  .sheet::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }
  .sheet::before {   /* senkrechte Mittellinie */
    top: 0; bottom: 0; left: 50%;
    border-left: 0.25mm dashed #b4b4b4;
  }
  .sheet::after {    /* waagerechte Mittellinie */
    left: 0; right: 0; top: 50%;
    border-top: 0.25mm dashed #b4b4b4;
  }
  {% endif %}

  /* Karten absolut positioniert (per Inline-Style je Zelle): so sind sie aus
     dem Fluss genommen und eine Seite kann niemals überlaufen/fragmentieren. */
  .card {
    position: absolute;
    width: {{ cell_w }}mm;
    height: {{ cell_h }}mm;
    padding: 7mm;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    line-height: 1.3;
  }

  /* ---------- Lochbereich (oben links auf der Vorderseite) ----------
     Das Loch wird durch die fertige Karte gestanzt und muss auf beiden
     Seiten frei bleiben. Die reservierte Zone liegt vorne oben LINKS;
     hinten je nach Wende-Kante gespiegelt, damit dasselbe physische Eck
     getroffen wird (long-edge → oben rechts, short-edge → unten links). */
  .hole {
    position: absolute;
    width: 6mm;
    height: 6mm;
    border: 0.3mm dashed #9a9a9a;
    border-radius: 50%;
  }
  .card.front .hole { top: 6mm; left: 6mm; }
  {% if duplex == "short-edge" %}
  .card.back .hole { bottom: 6mm; left: 6mm; }
  .card.back { padding-bottom: 15mm; }
  {% else %}
  .card.back .hole { top: 6mm; right: 6mm; }
  .card.back { padding-top: 15mm; }
  {% endif %}
  .card.empty .hole { display: none; }

  /* ---------- Vorderseite: nur das Kanji, riesig & zentriert ---------- */
  .card.front {
    align-items: center;
    justify-content: center;
  }
  .front .kanji {
    font-family: "KanjiFont", serif;
    font-size: 150pt;
    line-height: 1;
    font-weight: 600;
  }

  /* ---------- Deckkarte: Vorderseite ---------- */
  .cover-front {
    align-items: center;
    justify-content: center;
    background: #0098c8;   /* WaniKani-Blau */
    color: #fff;
  }
  .cover-front .hole { border-color: rgba(255, 255, 255, 0.75); }
  .cover-brand {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 30pt;
    letter-spacing: 0.5px;
    line-height: 1.05;
  }
  .cover-level {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 44pt;
    line-height: 1.1;
    margin-top: 3mm;
  }
  .cover-count {
    font-size: 12pt;
    opacity: 0.85;
    margin-top: 3mm;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ---------- Deckkarte: Rückseite (Kanji-Übersicht) ---------- */
  .cover-back { display: block; }
  .cover-back-title {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 12pt;
    color: #0098c8;
    margin-bottom: 2.5mm;
  }
  /* Spaltenzahl + Basis-Schriftgröße werden je nach Kanji-Anzahl per
     Inline-Style gesetzt (siehe unten); .cl-* skalieren relativ dazu (em),
     damit auch volle Level (~35+ Kanji) sauber auf die Karte passen. */
  ul.cover-list {
    list-style: none;
    margin: 0;
    padding: 0;
    column-gap: 5mm;
    font-size: 10pt;   /* Default; per Inline-Style überschrieben */
  }
  ul.cover-list li {
    display: flex;
    align-items: baseline;
    gap: 1.6mm;
    break-inside: avoid;
    margin-bottom: 0.55em;
  }
  ul.cover-list .cl-k {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 1.35em;
    font-weight: 600;
    flex: 0 0 auto;
  }
  ul.cover-list .cl-m {
    font-size: 0.92em;
    color: #555;
    line-height: 1.12;
  }

  /* ---------- Rückseite ----------
     Normaler Blockfluss (kein Flex): so kann kein Abschnitt flex-geschrumpft
     werden und Texte überlappen nie; zu viel Inhalt wird am Kartenrand
     sauber abgeschnitten (overflow:hidden). */
  .card.back {
    display: block;
  }
  .back .meanings {
    font-family: "SansJP", sans-serif;
    font-weight: 700;
    font-size: 14pt;
    line-height: 1.12;
    color: #111;
    margin-bottom: 2mm;
  }
  .back .meanings .secondary {
    font-weight: 400;
    font-size: 10pt;
    color: #666;
  }

  .readings {
    margin-bottom: 2mm;
  }
  .readings .reading-row + .reading-row { margin-top: 1mm; }
  .reading-row {
    display: flex;
    align-items: baseline;
    gap: 2.5mm;
  }
  .reading-row .label {
    flex: 0 0 15mm;
    font-size: 8pt;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #a23b2e;   /* dezentes WaniKani-Rot für On */
    font-weight: 700;
    padding-top: 1pt;
  }
  .reading-row.kun .label { color: #2e5aa2; }  /* Blau für Kun */
  .reading-row .value {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 13pt;
    line-height: 1.3;
    color: #1a1a1a;
  }

  /* ---------- Eselsbrücken (Mnemonics) ---------- */
  .mnemonics {
    background: #faf7f1;
    border-left: 0.7mm solid #e2d6c2;
    border-radius: 0.6mm;
    padding: 1.6mm 2.2mm;
    margin-bottom: 2mm;
  }
  .mnemonic {
    font-size: 7.4pt;
    line-height: 1.28;
    color: #5a544c;
    text-align: justify;
  }
  .mnemonic + .mnemonic { margin-top: 1mm; }
  .mnemonic .mlabel {
    display: inline-block;
    font-size: 6.3pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin-right: 1.4mm;
    vertical-align: 1.5%;
  }
  .mnemonic .mlabel.meaning { color: #a2792e; }
  .mnemonic .mlabel.reading { color: #7a5a9e; }

  hr.divider {
    border: none;
    border-top: 0.3mm solid #e6e6e6;
    margin: 0.6mm 0;
    width: 100%;
  }

  .vocab {
    display: flex;
    flex-direction: column;
    gap: 0.8mm;
  }
  .vocab .head {
    display: flex;
    align-items: baseline;
    gap: 2.5mm;
  }
  .vocab .word {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 15pt;
    font-weight: 600;
  }
  .vocab .vreading {
    font-family: "KanjiFont", "SansJP", serif;
    font-size: 11pt;
    color: #444;
  }
  .vocab .gloss {
    font-size: 10pt;
    color: #555;
  }

  .sentence {
    margin-top: 1.6mm;
  }
  .sentence .ja {
    font-family: "SansJP", sans-serif;
    font-size: 10pt;
    line-height: 1.35;
    color: #1a1a1a;
    word-break: break-all;   /* sauberer CJK-Umbruch */
    line-break: strict;
  }
  .sentence .en {
    font-size: 8.5pt;
    line-height: 1.35;
    color: #777;
    font-style: italic;
    margin-top: 0.6mm;
  }

  /* Kleines Referenz-Kanji im reservierten Loch-Band (Gegenseite zum Loch). */
  .kanji-mini {
    position: absolute;
    top: 4.5mm;
    font-family: "KanjiFont", serif;
    font-size: 19pt;
    line-height: 1;
    color: #cfcfcf;
    font-weight: 600;
  }
  {% if duplex == "short-edge" %}
  .kanji-mini { top: auto; bottom: 4.5mm; right: 6mm; }
  {% else %}
  .kanji-mini { left: 6mm; }
  {% endif %}
</style>
</head>
<body>
{% for sheet in sheets %}
  <div class="sheet">
    {% for cell in sheet.cells %}
      {% set col = loop.index0 % cols %}
      {% set row = loop.index0 // cols %}
      {% set pos = "left:" ~ (col * cell_w) ~ "mm; top:" ~ (row * cell_h) ~ "mm;" %}
      {% if cell is none %}
        <div class="card empty" style="{{ pos }}"></div>
      {% elif sheet.side == "front" %}
        {% if cell.type == "cover" %}
        <div class="card front cover-front" style="{{ pos }}">
          {% if cut_marks %}<div class="hole"></div>{% endif %}
          <div class="cover-brand">{{ cell.title }}</div>
          <div class="cover-level">{{ cell.subtitle }}</div>
          <div class="cover-count">{{ cell.count }} Kanji</div>
        </div>
        {% else %}
        <div class="card front" style="{{ pos }}">
          {% if cut_marks %}<div class="hole"></div>{% endif %}
          <div class="kanji">{{ cell.kanji }}</div>
        </div>
        {% endif %}
      {% elif cell.type == "cover" %}
        {# Spalten & Schriftgröße an die Kanji-Anzahl anpassen, damit auch
           volle Level vollständig auf die Karte passen. #}
        {% set n = cell.count %}
        {% if n <= 10 %}{% set lcols, lfs = 2, 11 %}
        {% elif n <= 21 %}{% set lcols, lfs = 3, 9.5 %}
        {% elif n <= 32 %}{% set lcols, lfs = 3, 8 %}
        {% elif n <= 44 %}{% set lcols, lfs = 4, 7.5 %}
        {% else %}{% set lcols, lfs = 4, 6.5 %}{% endif %}
        <div class="card back cover-back" style="{{ pos }}">
          {% if cut_marks %}<div class="hole"></div>{% endif %}
          <div class="cover-back-title">{{ cell.subtitle }} · Übersicht</div>
          <ul class="cover-list" style="columns: {{ lcols }}; font-size: {{ lfs }}pt;">
            {% for e in cell.entries %}
            <li><span class="cl-k">{{ e.kanji }}</span><span class="cl-m">{{ e.meaning }}</span></li>
            {% endfor %}
          </ul>
        </div>
      {% else %}
        <div class="card back" style="{{ pos }}">
          {% if cut_marks %}<div class="hole"></div>{% endif %}
          <div class="kanji-mini">{{ cell.kanji }}</div>

          {% if cell.meanings %}
          <div class="meanings">
            {{ cell.meanings[0] }}{% if cell.meanings[1:] %}<span class="secondary">&nbsp;· {{ cell.meanings[1:] | join(", ") }}</span>{% endif %}
          </div>
          {% endif %}

          <div class="readings">
            {% if cell.onyomi %}
            <div class="reading-row on">
              <div class="label">On</div>
              <div class="value">{{ cell.onyomi | join("、") }}</div>
            </div>
            {% endif %}
            {% if cell.kunyomi %}
            <div class="reading-row kun">
              <div class="label">Kun</div>
              <div class="value">{{ cell.kunyomi | join("、") }}</div>
            </div>
            {% endif %}
          </div>

          {% if cell.meaning_mnemonic or cell.reading_mnemonic %}
          <div class="mnemonics">
            {% if cell.meaning_mnemonic %}
            <div class="mnemonic"><span class="mlabel meaning">Meaning</span>{{ cell.meaning_mnemonic }}</div>
            {% endif %}
            {% if cell.reading_mnemonic %}
            <div class="mnemonic"><span class="mlabel reading">Reading</span>{{ cell.reading_mnemonic }}</div>
            {% endif %}
          </div>
          {% endif %}

          {% if cell.vocab %}
          <hr class="divider">
          <div class="vocab">
            <div class="head">
              <span class="word">{{ cell.vocab }}</span>
              {% if cell.vocab_reading %}<span class="vreading">{{ cell.vocab_reading }}</span>{% endif %}
              {% if cell.vocab_meaning %}<span class="gloss">{{ cell.vocab_meaning }}</span>{% endif %}
            </div>
          </div>
          {% endif %}

          {% if cell.sentence_ja %}
          <div class="sentence">
            <div class="ja">{{ cell.sentence_ja }}</div>
            {% if cell.sentence_en %}<div class="en">{{ cell.sentence_en }}</div>{% endif %}
          </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
{% endfor %}
</body>
</html>
